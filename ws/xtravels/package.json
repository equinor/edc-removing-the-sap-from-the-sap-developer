{
  "name": "@capire/xtravels",
  "version": "1.0.0",
  "description": "CAP SFlight travel service demo TE2025",
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "test": "chest test",
    "jest": "npx jest"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@cap-js/xsrv-federation": ".plugins/fed-xrv",
    "@cap-js/dp-by-synonym": ".plugins/dp-syn",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap/xsenv": "^6",
    "@sap/xssec": "^4.9",
    "@sap/cds": ">=9.4",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "*",
    "@cap-js/sqlite": ">=2"
  },
  "license": "Apache-2.0",
  "cds": {
    "requires": {
      "connectivity": true,
      "destination": true,
      "html5-repo": true,
      "authentication": "xsuaa",
      "SAP_ICSM_BusinessPartnerExt": {
        "kind": "odata-v2",
        "model": "srv/external/SAP_ICSM_BusinessPartnerExt",
        "credentials": {
          "destination": "EDC_API_BUSINESS_PARTNER",
          "path": "/sap/opu/odata/sap/API_BUSINESS_PARTNER"
        }
      }
    }
  }
}