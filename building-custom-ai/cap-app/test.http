### Variables
@baseUrl = http://localhost:4004/api
@auth = alice:

###
# ─────────────────────────────────────────────
#  RAG – askQuestion
# ─────────────────────────────────────────────

### 1. RGB backlight keyboards (notebook test case 1)
POST {{baseUrl}}/askQuestion
Content-Type: application/json
Authorization: Basic {{auth}}

{
    "question": "Find all keyboards with RGB backlighting"
}

### 2. Cheapest wireless mouse (notebook test case 2)
POST {{baseUrl}}/askQuestion
Content-Type: application/json
Authorization: Basic {{auth}}

{
    "question": "What is the cheapest wireless mouse available? Return only one."
}

### 3. Headset with rating 5 (notebook test case 3)
POST {{baseUrl}}/askQuestion
Content-Type: application/json
Authorization: Basic {{auth}}

{
    "question": "Suggest a headset with a rating of 5. Return only one."
}

### 4. Single RGB keyboard (notebook free-form example)
POST {{baseUrl}}/askQuestion
Content-Type: application/json
Authorization: Basic {{auth}}

{
    "question": "Find a single keyboard with RGB backlighting"
}

### 5. Single cheapest wireless mouse (notebook free-form example)
POST {{baseUrl}}/askQuestion
Content-Type: application/json
Authorization: Basic {{auth}}

{
    "question": "What is the single cheapest wireless mouse available?"
}

###
# ─────────────────────────────────────────────
#  CDS – Products entity (read-only)
# ─────────────────────────────────────────────

### Browse all products
GET {{baseUrl}}/Products
Authorization: Basic {{auth}}

### Filter keyboards
GET {{baseUrl}}/Products?$filter=contains(productName,'Keyboard')&$orderby=unitPrice asc
Authorization: Basic {{auth}}

### Top 5 highest rated products
GET {{baseUrl}}/Products?$orderby=rating desc&$top=5
Authorization: Basic {{auth}}
