{
    "name": "edc-rag-cap-app",
    "version": "1.0.0",
    "description": "CAP RAG HANA Cloud vector engine + SAP AI Core",
    "private": true,
    "dependencies": {
        "@sap/cds": "^8",
        "@sap-ai-sdk/foundation-models": "^1",
        "@sap/hana-client": "^2",
        "express": "^4"
    },
    "devDependencies": {
        "@sap/cds-dk": "^8",
        "@cap-js/sqlite": "^1"
    },
    "scripts": {
        "start": "cds-serve",
        "watch": "cds watch",
        "deploy": "cds deploy --to sqlite && node scripts/generate-embeddings.js"
    },
    "cds": {
        "requires": {
            "db": {
                "kind": "sqlite",
                "credentials": {
                    "url": "db.sqlite"
                }
            }
        }
    }
}